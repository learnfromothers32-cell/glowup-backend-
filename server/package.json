  "version": "1.0.0",
  "description": "GlowUp OS - Startup Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed": "ts-node-dev --transpile-only --exit-child src/seed/seed.ts",
