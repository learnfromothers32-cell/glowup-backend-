    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.25",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
